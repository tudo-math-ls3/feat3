<ParameterList name="Scalexa Feat-Frosch Pressure Poisson Template">
    <Parameter name="Preconditioner Type" type="string" value="FROSch"/>
    <ParameterList name="Preconditioner Types">
        <ParameterList name="FROSch">
            <Parameter name="Dimension"                                         type="int"      value="2"/>
            <Parameter name="Overlap"                                           type="int"      value="1"/>
            <Parameter name="DofsPerNode"                                       type="int"      value="3"/>
            <Parameter name="DofOrdering"                                       type="string"   value="NodeWise"/>
            <!-- <Parameter name="DofOrdering"                                       type="string"   value="DimensionWise"/> -->
            <Parameter name="FROSch Preconditioner Type"                        type="string"   value="TwoLevelBlockPreconditioner"/>
            <!-- <Parameter name="FROSch Preconditioner Type"                        type="string"   value="TwoLevelPreconditioner"/> -->
            <Parameter name="OverlappingOperator Type"                          type="string"   value="AlgebraicOverlappingOperator"/>
            <Parameter name="CoarseOperator Type"                               type="string"   value="IPOUHarmonicCoarseOperator"/>
            <!-- <Parameter name="Null Space Type"                                   type="string"   value="Stokes-Feat-Pres-P1Disc"/> -->
            <Parameter name="Null Space Type"                                   type="string"   value="Input"/>
            <!-- Auf Dimension des Grobgitterproblems achten -->

            <ParameterList name="AlgebraicOverlappingOperator">
                <!-- BEGIN: UNCOMMENT FOR USE OF MUMPS -->
                <Parameter name="Reuse: Symbolic Factorization" type="bool" value="false"/>
                <!-- END: UNCOMMENT FOR USE OF MUMPS -->
                <ParameterList name="Solver">
                    <Parameter name="SolverType"                                type="string"   value="Amesos2"/>
                    <!-- <Parameter name="Solver"                                    type="string"   value="Klu"/> -->
                    <Parameter name="Solver"                                    type="string"   value="Mumps"/>
                    <!-- <Parameter name="Solver"                                    type="string"   value="Umfpack"/> -->
                </ParameterList>

                <!-- BEGIN: UNCOMMENT FOR USE OF ILU -->
                <!--     <Parameter name="SolverType"                                type="string" value="Ifpack2"/> -->
                <!--     <Parameter name="Solver"                                    type="string" value="RILUK"/> -->
                <!--     <ParameterList name="Ifpack2"> -->
                <!--         <Parameter name="fact: iluk level-of-fill"              type="int"      value="3"/> -->
                <!--     </ParameterList> -->
                <!-- END: UNCOMMENT FOR USE OF ILU -->

                <Parameter name="Combine Values in Overlap"                     type="string" value="Restricted"/>
            </ParameterList>

            <ParameterList name="Blocks">
                <ParameterList name="1">
                    <!-- THIS IS THE PRESSURE POISSON BLOCK -->
                    <Parameter name="Dofs Per Node"                         type="int"     value="3"/>
                </ParameterList>
            </ParameterList>

            <ParameterList name="IPOUHarmonicCoarseOperator">
                <ParameterList name="Blocks">

                    <ParameterList name="1">
                        <!-- THIS IS THE PRESSURE POISSON BLOCK -->
                        <Parameter name="Use For Coarse Space"                  type="bool"     value="true"/>
                        <Parameter name="Rotations"                             type="bool"     value="false"/>

                        <ParameterList name="InterfacePartitionOfUnity">
                            <Parameter name="Type"                              type="string"   value="GDSW"/>
                            <!-- <Parameter name="Type"                              type="string"   value="GDSWStar"/> -->
                            <!-- <Parameter name="Type"                              type="string"   value="RGDSW"/> -->

                            <!-- CONFIGURE FOR OTHER COARSE SPACE-->
                            <ParameterList name="GDSW">
                                <Parameter name="Type"                          type="string"   value="Full"/>
                                <Parameter name="Distance Function"             type="string"   value="Constant"/>
                                <ParameterList name="Custom">
                                    <Parameter name="Roots"                     type="bool"     value="true"/>
                                </ParameterList>
                            </ParameterList>
                        </ParameterList>
                    </ParameterList>

                </ParameterList>

                <ParameterList name="ExtensionSolver">
                    <Parameter name="SolverType"                                type="string"   value="Amesos2"/>
                    <!-- <Parameter name="Solver"                                    type="string"   value="Klu"/> -->
                    <!-- <Parameter name="Solver"                                    type="string"   value="Mumps"/> -->
                    <Parameter name="Solver"                                    type="string"   value="Umfpack"/>

                    <!-- BEGIN: UNCOMMENT FOR USE OF MUMPS -->
                    <!-- <Parameter name="Reuse symbolic factorization" type="bool" value="false"/> -->
                    <!-- <ParameterList name="MUMPS"> -->
                    <!--     <Parameter name="Reuse SymbolicFactorization" type="bool" value="true"/> -->
                    <!-- </ParameterList> -->
                    <!-- END: UNCOMMENT FOR USE OF MUMPS -->
                </ParameterList>

                <ParameterList name="Distribution">
                    <!-- NUMBER OF SUBREGIONS -->
                    <Parameter name="NumProcs"                                  type="int"      value="4"/>
                    <Parameter name="Type"                                      type="string"   value="ZoltanDual"/>
                    <ParameterList name="Zoltan2 Parameter">
                        <Parameter name="algorithm"                          type="string"   value="parmetis"/>
                        <!-- <Parameter name="algorithm"                          type="string"   value="block"/> -->

                        <Parameter name="imbalance_tolerance"                type="double"   value="1.1"/>
                        <Parameter name="partitioning_approach"              type="string"   value="partition"/>
                        <!-- <Parameter name="partitioning_approach"              type="string"   value="repartition"/> -->
                        <!-- sets num_global_parts = NumProc()/num_global_parts_fraction -->
                    </ParameterList>

                    <Parameter name="Factor"                                    type="double"   value="1.0"/>
                    <Parameter name="GatheringSteps"                            type="int"      value="1"/>
                    <ParameterList name="Gathering Communication">
                        <Parameter name="Send type"                             type="string"   value="Send"/>
                    </ParameterList>
                </ParameterList>

                <ParameterList name="CoarseSolver">
                    <Parameter name="SolverType"                                  type="string"    value="FROSchPreconditioner"/>
                    <Parameter name="Solver"                                      type="string"    value="TwoLevelBlockPreconditioner"/>

                    <ParameterList name="FROSchPreconditioner">

                        <ParameterList name="TwoLevelBlockPreconditioner">
                            <Parameter name="Dimension"                                 type="int"              value="2"/>
                            <Parameter name="Overlap"                                   type="int"              value="1"/>
                            <Parameter name="Default BlockId Subdomain Graph"           type="int"              value="1"/>
                            <Parameter name="Level ID"                                  type="unsigned int"     value="2"/>
                            <Parameter name="OverlappingOperator Type"                  type="string"           value="AlgebraicOverlappingOperator"/>
                            <Parameter name="CoarseOperator Type"                       type="string"           value="IPOUHarmonicCoarseOperator"/>
                            <Parameter name="Null Space Type"                           type="string"           value="Laplace"/>

                            <ParameterList name="AlgebraicOverlappingOperator">
                                <!-- BEGIN: UNCOMMENT FOR USE OF MUMPS -->
                                <Parameter name="Reuse: Symbolic Factorization" type="bool" value="false"/>
                                <!-- END: UNCOMMENT FOR USE OF MUMPS -->
                                <ParameterList name="Solver">
                                    <Parameter name="SolverType"                                type="string"   value="Amesos2"/>
                                    <!-- <Parameter name="Solver"                                    type="string"   value="Klu"/> -->
                                    <Parameter name="Solver"                                    type="string"   value="Mumps"/>
                                    <!-- <Parameter name="Solver"                                    type="string"   value="Umfpack"/> -->
                                </ParameterList>

                                <!-- BEGIN: UNCOMMENT FOR USE OF ILU -->
                                <!--     <Parameter name="SolverType"                                type="string" value="Ifpack2"/> -->
                                <!--     <Parameter name="Solver"                                    type="string" value="RILUK"/> -->
                                <!--     <ParameterList name="Ifpack2"> -->
                                <!--         <Parameter name="fact: iluk level-of-fill"              type="int"      value="3"/> -->
                                <!--     </ParameterList> -->
                                <!-- END: UNCOMMENT FOR USE OF ILU -->

                                <Parameter name="Combine Values in Overlap"                     type="string" value="Restricted"/>
                            </ParameterList>

                            <ParameterList name="IPOUHarmonicCoarseOperator">

                                <ParameterList name="Blocks">

                                    <ParameterList name="1">
                                        <!-- THIS IS THE VELOCITY BLOCK -->
                                        <Parameter name="Use For Coarse Space"                  type="bool"     value="true"/>
                                        <Parameter name="Rotations"                             type="bool"     value="false"/>

                                        <ParameterList name="InterfacePartitionOfUnity">
                                            <Parameter name="Type"                              type="string"   value="GDSW"/>
                                            <!-- <Parameter name="Type"                              type="string"   value="GDSWStar"/> -->
                                            <!-- RGDSW IS OFTEN NOT A GOOD IDEA (FOR STOKES!!) -->
                                            <!-- <Parameter name="Type"                              type="string"   value="RGDSW"/> -->

                                            <!-- CONFIGURE FOR OTHER COARSE SPACE-->
                                            <ParameterList name="GDSW">
                                                <Parameter name="Type"                          type="string"   value="Full"/>
                                                <Parameter name="Distance Function"             type="string"   value="Constant"/>
                                                <ParameterList name="Custom">
                                                    <Parameter name="Roots"                     type="bool"     value="true"/>
                                                </ParameterList>
                                            </ParameterList>
                                        </ParameterList>
                                    </ParameterList>

                                </ParameterList>

                                <ParameterList name="ExtensionSolver">
                                    <Parameter name="SolverType"                                type="string"   value="Amesos2"/>
                                    <!-- <Parameter name="Solver"                                    type="string"   value="Klu"/> -->
                                    <!-- <Parameter name="Solver"                                    type="string"   value="Mumps"/> -->
                                    <Parameter name="Solver"                                    type="string"   value="Umfpack"/>

                                    <!-- BEGIN: UNCOMMENT FOR USE OF MUMPS -->
                                    <!-- <Parameter name="Reuse symbolic factorization" type="bool" value="false"/> -->
                                    <!-- <ParameterList name="MUMPS"> -->
                                    <!--     <Parameter name="Reuse SymbolicFactorization" type="bool" value="true"/> -->
                                    <!-- </ParameterList> -->
                                    <!-- END: UNCOMMENT FOR USE OF MUMPS -->
                                </ParameterList>

                                <ParameterList name="Distribution">
                                    <Parameter name="Type"                                      type="string"   value="linear"/>
                                    <Parameter name="NumProcs"                                  type="int"      value="1"/>
                                    <Parameter name="Factor"                                    type="double"   value="1.0"/>
                                    <Parameter name="GatheringSteps"                            type="int"      value="1"/>
                                    <ParameterList name="Gathering Communication">
                                        <Parameter name="Send type"                             type="string"   value="Send"/>
                                    </ParameterList>
                                </ParameterList>

                                <ParameterList name="CoarseSolver">
                                    <Parameter name="SolverType"                                type="string"   value="Amesos2"/>
                                    <!-- <Parameter name="Solver"                                    type="string"   value="Klu"/> -->
                                    <!-- <Parameter name="Solver"                                    type="string"   value="Umfpack"/> -->
                                    <Parameter name="Solver"                                    type="string"   value="Mumps"/>

                                    <!-- BEGIN: UNCOMMENT FOR USE OF ILU -->
                                    <!--     <Parameter name="SolverType"                                type="string" value="Ifpack2"/> -->
                                    <!--     <Parameter name="Solver"                                    type="string" value="RILUK"/> -->
                                    <!--     <ParameterList name="Ifpack2"> -->
                                    <!--         <Parameter name="fact: iluk level-of-fill"              type="int"      value="3"/> -->
                                    <!--     </ParameterList> -->
                                    <!-- END: UNCOMMENT FOR USE OF ILU -->

                                </ParameterList>

                            </ParameterList>

                        </ParameterList>

                    </ParameterList>

                </ParameterList>

            </ParameterList>

        </ParameterList>

    </ParameterList>

</ParameterList>
